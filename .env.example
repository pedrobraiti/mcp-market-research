# Scout (mcp-market-research) — environment configuration.
# Copy to `.env` and adjust. All keys are optional for the current data sources
# (yfinance needs no key); they are here for upcoming adapters and tuning.

# Logging
SCOUT_LOG_LEVEL=INFO

# Network
SCOUT_REQUEST_TIMEOUT_SECONDS=15

# SEC EDGAR requires an identifiable User-Agent (e.g. "Your Name your@email.com").
# Used by the upcoming filings adapter; harmless if unset until then.
SCOUT_SEC_USER_AGENT=
